# Environment Variables — a2a-copilot
#
# Copy this file to .env and fill in the values you need.
# Never commit .env to source control.
#
# Most settings can also be provided via a JSON config file or CLI flags.
# Priority order: defaults < config JSON < environment variables < CLI flags

# ---------------------------------------------------------------------------
# GitHub Copilot Authentication
# ---------------------------------------------------------------------------

# Personal Access Token with Copilot access.
# Required when running headless (without the `gh` CLI authenticated).
# GITHUB_TOKEN=

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------

# Port the A2A HTTP server listens on (default: 3000)
# PORT=3000

# Bind address (default: 0.0.0.0)
# HOSTNAME=0.0.0.0

# Hostname embedded in agent card URLs — set to your machine's IP or domain
# when running behind Docker or a reverse proxy (default: localhost)
# ADVERTISE_HOST=localhost

# ---------------------------------------------------------------------------
# Copilot
# ---------------------------------------------------------------------------

# LLM model to use (default: gpt-4.1)
# Available: gpt-4.1, claude-sonnet-4.5, etc.
# COPILOT_MODEL=gpt-4.1

# URL of an external Copilot CLI if you're running it separately (default: auto)
# COPILOT_CLI_URL=localhost:4321

# Workspace directory made available to the agent (default: empty)
# WORKSPACE_DIR=/path/to/workspace

# ---------------------------------------------------------------------------
# Bring Your Own Model (BYOK) — custom LLM provider
# ---------------------------------------------------------------------------
#
# Set these to bypass GitHub Copilot and use your own OpenAI-compatible
# endpoint (Ollama, OpenAI, Anthropic, Azure, vLLM, etc.). Leave them unset
# to use GitHub Copilot's hosted models.
#
# When using a provider, COPILOT_MODEL is REQUIRED.
# See the "Bring Your Own Model (BYOK)" section of the README for details,
# including the native tool-calling requirement for local models.

# Provider API endpoint. For local Ollama: http://localhost:11434/v1
# COPILOT_PROVIDER_BASE_URL=http://localhost:11434/v1

# Provider type: openai | azure | anthropic (default: openai)
# COPILOT_PROVIDER_TYPE=openai

# API key. Not required for local providers like Ollama.
# COPILOT_PROVIDER_API_KEY=

# Wire API: completions | responses (default: completions)
# Use "completions" for Ollama and most local engines.
# COPILOT_PROVIDER_WIRE_API=completions

# ---------------------------------------------------------------------------
# Agent Card (overrides config file)
# ---------------------------------------------------------------------------

# AGENT_NAME=My Copilot Agent
# AGENT_DESCRIPTION=What my agent does

# ---------------------------------------------------------------------------
# Features
# ---------------------------------------------------------------------------

# Stream artifact chunks in real time (A2A spec mode).
# Set to "true" for streaming clients; leave unset for buffered (Inspector-compatible) mode.
# STREAM_ARTIFACTS=false

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Log level: debug | info | warn | error (default: info)
# LOG_LEVEL=info
