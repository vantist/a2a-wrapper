{
  "name": "a2a-codex",
  "version": "1.6.0",
  "description": "A2A (Agent-to-Agent) protocol wrapper for OpenAI Codex SDK. Drop a JSON config file in, get a fully-spec-compliant A2A server out. Supports repository sandboxing, MCP tools, streaming sideband events, and multi-agent delegation.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "a2a-codex": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "stop": "pkill -f 'node dist/cli.js' || true",
    "clean": "rm -rf dist",
    "rebuild": "npm run clean && npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run --passWithNoTests"
  },
  "files": [
    "dist",
    "agents",
    "schemas",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "a2a",
    "agent-to-agent",
    "openai",
    "codex",
    "codex-sdk",
    "ai-agents",
    "mcp",
    "model-context-protocol",
    "interoperability",
    "multi-agent",
    "streaming",
    "repository-sandbox"
  ],
  "author": "Shashi Kanth <124822098+shashikanth-gs@users.noreply.github.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shashikanth-gs/a2a-wrapper.git",
    "directory": "a2a-codex"
  },
  "homepage": "https://github.com/shashikanth-gs/a2a-wrapper/tree/main/a2a-codex#readme",
  "bugs": {
    "url": "https://github.com/shashikanth-gs/a2a-wrapper/issues"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.9",
    "@a2a-wrapper/core": "1.6.1",
    "@openai/codex-sdk": "^0.137.0",
    "express": "^4.18.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
