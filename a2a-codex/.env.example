# Environment Variables — a2a-codex
#
# Copy this file to .env and fill in the values you need.
# Never commit .env to source control.
#
# Most settings can also be provided via a JSON config file or CLI flags.
# Priority order: defaults < config JSON < environment variables < CLI flags

# ---------------------------------------------------------------------------
# OpenAI Authentication
# ---------------------------------------------------------------------------

# OpenAI API key — required for Codex SDK access.
# OPENAI_API_KEY=sk-...

# ---------------------------------------------------------------------------
# Workspace
# ---------------------------------------------------------------------------

# Absolute path to the Git repository Codex will operate in.
# Required. Can also be set via --workspace CLI flag or codex.workingDirectory
# in config.json.
# WORKSPACE_DIR=/path/to/your/repo

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------

# Port the A2A HTTP server listens on (default: 3020)
# PORT=3020

# Bind address (default: 0.0.0.0)
# HOSTNAME=0.0.0.0

# Hostname embedded in agent card URLs — set to your machine's IP or domain
# when running behind Docker or a reverse proxy (default: localhost)
# ADVERTISE_HOST=localhost

# ---------------------------------------------------------------------------
# Codex
# ---------------------------------------------------------------------------

# LLM model to use (default: determined by Codex SDK)
# Examples: o4-mini, o3, gpt-4o
# CODEX_MODEL=o4-mini

# ---------------------------------------------------------------------------
# Agent Card (overrides config file)
# ---------------------------------------------------------------------------

# AGENT_NAME=My Codex Agent
# AGENT_DESCRIPTION=What my agent does

# ---------------------------------------------------------------------------
# Features
# ---------------------------------------------------------------------------

# Stream artifact chunks in real time (A2A spec mode).
# Set to "true" for streaming clients; leave unset for buffered (Inspector-compatible) mode.
# STREAM_ARTIFACTS=false

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Log level: debug | info | warn | error (default: info)
# LOG_LEVEL=info
